# Copy this file to .env.local on the server/local machine and fill real values there.
# .env.local is intentionally ignored by git so credentials are never pushed.

# Super admin receives full platform analytics across all shops and users.
SUPER_ADMIN_EMAIL=admin@example.com

# Gmail/SMTP sender used for all report emails.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=your-gmail-app-password
MAIL_FROM=yourgmail@gmail.com

# Daily report schedule in server local time. 0:0 means 12:00 AM.
DAILY_REPORT_HOUR=0
DAILY_REPORT_MINUTE=0

# Browser push notifications. Generate with: npx web-push generate-vapid-keys
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:support@printpanda.in

# Shop admin email is saved in the web admin shop create/edit form.
# Desktop/operator user email is saved in the web admin user create form or desktop settings.
